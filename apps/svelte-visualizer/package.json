{
  "name": "svelte-visualizer",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "start": "vite preview --port 5173",
    "lint": "eslint . --max-warnings 0",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@repo/contracts": "workspace:*",
    "@repo/design-system": "workspace:*",
    "@repo/event-bus": "workspace:*",
    "@repo/headless": "workspace:*",
    "@repo/sdk": "workspace:*",
    "svelte": "^5.38.6"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "svelte-check": "^4.0.0",
    "typescript": "5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
