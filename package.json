{
  "name": "monorepo-mfe",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=nuxt-host --filter=svelte-visualizer",
    "start": "turbo run start --filter=nuxt-host --filter=svelte-visualizer",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,vue,svelte,css,md}\"",
    "check-types": "turbo run check-types",
    "check-types:role-demo": "turbo run check-types --filter=nuxt-host --filter=svelte-visualizer --filter=@repo/contracts --filter=@repo/headless --filter=@repo/design-system --filter=@repo/event-bus --filter=@repo/sdk"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
